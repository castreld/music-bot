# Discord bot token — from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your bot's Application ID (General Information page)
CLIENT_ID=your_client_id_here

# Guild ID for instant dev command registration (remove for global registration)
GUILD_ID=your_test_guild_id_here

# Gemini API key — used for autoplay recommendations AND /dj-announce scripts
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (Optional) Groq API key — fallback for /dj-announce when Gemini is rate-limited
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=

# Google Cloud TTS credentials for /dj-announce (JSON service account key, single line)
# Setup: GCP Console → APIs & Services → Enable "Cloud Text-to-Speech API"
#        → IAM & Admin → Service Accounts → Create → role "Cloud Text-to-Speech User"
#        → Keys → Add Key → JSON → paste the full JSON content here (minified, one line)
GOOGLE_CLOUD_TTS_KEY=

# (Optional) Genius API key for more reliable lyrics fetching
# Get one free at https://genius.com/api-clients
GENIUS_API_KEY=

# (Optional, unused) Path to yt-dlp binary.
# Playback/search in this bot uses play-dl + youtubei.js, not yt-dlp.
YT_DLP_PATH=yt-dlp

# Path to ffmpeg binary (leave as 'ffmpeg' if it is in your PATH)
FFMPEG_PATH=ffmpeg
